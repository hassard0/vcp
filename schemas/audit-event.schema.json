{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hassard0/vcp/schemas/audit-event.schema.json",
  "title": "VCP Audit Event",
  "description": "Every invocation MUST emit a signed audit event, OpenTelemetry-compatible. Audit events MUST NOT contain secrets and SHOULD carry only hashes of sensitive arguments. Designed to be consumed by a ledger substrate (mcp-ledger). See SPECIFICATION.md §19, §20.",
  "type": "object",
  "additionalProperties": false,
  "required": ["event", "trace_id", "subject", "capability_id", "decision", "timestamp"],
  "properties": {
    "event": {
      "type": "string",
      "description": "Event type, e.g. vcp.capability.invoked, vcp.grant.minted, vcp.policy.denied, vcp.attestation.rejected."
    },
    "trace_id": { "type": "string", "description": "OpenTelemetry trace id." },
    "span_id": { "type": "string" },
    "traceparent": { "type": "string", "description": "W3C Trace Context traceparent (§25), e.g. 00-<trace-id>-<span-id>-01." },
    "tracestate": { "type": "string", "description": "W3C Trace Context tracestate (§25)." },
    "subject": { "type": "string" },
    "host": { "type": "string" },
    "model": { "type": "string" },
    "provider": { "type": "string" },
    "capability_id": {
      "type": "string",
      "pattern": "^vcp:cap:[A-Za-z0-9._-]+@sha256:[0-9a-f]{64}$"
    },
    "plan_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "argument_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "grant_id": { "type": "string" },
    "delegation_chain": {
      "type": "array",
      "description": "On-behalf-of chain for this call (§26.2, §26.5): who authorized it and on whose behalf it ran.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "id"],
        "properties": {
          "role": { "enum": ["authorizer", "delegate", "enforcer", "executor", "resource"] },
          "id": { "type": "string" }
        }
      }
    },
    "credential_audience": { "type": "string", "description": "Audience of the exchanged upstream credential (§26.5), by reference — never the token." },
    "decision": { "enum": ["allow", "deny", "challenge"] },
    "reason_code": { "type": "string" },
    "effect": {
      "enum": ["read-only", "propose-only", "write-idempotent", "write-reversible", "write-irreversible"]
    },
    "result_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "effect_committed": { "type": "boolean" },
    "budget_spent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "usd": { "type": "number", "minimum": 0 },
        "tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "alg": { "type": "string", "default": "Ed25519" },
        "value": { "type": "string" }
      }
    }
  }
}
